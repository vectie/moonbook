  "        },\n" +
  "        \"steps\": [\n" +
  "          {\n" +
  "            \"id\": \"analyze_three_gaps\",\n" +
  "            \"title\": \"Analyze outcome evidence through Three-Gap theory\",\n" +
  "            \"kind\": \"job.analysis\",\n" +
  "            \"prompt_template\": \"" +
  escape_json_string(bookkeeper_three_gap_analyze_prompt()) +
  "\",\n" +
  "            \"metadata\": {\n" +
  "              \"model\": \"codex/gpt-5.6-sol\",\n" +
  "              \"output_contract\": \"moonbook.bookkeeper.moonclaw-result.v1\",\n" +
  "              \"result_contract\": {\n" +
  "                \"contract_version\": \"moonbook.bookkeeper.moonclaw-result.v1\",\n" +
  "                \"candidate_schema\": \"three_gap_finding.v1\",\n" +
  "                \"candidate_cardinality\": 1,\n" +
  "                \"candidate_stage\": \"three_gap_finding\",\n" +
