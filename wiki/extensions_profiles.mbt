  "              \"board_lane\": \"MoonCode\",\n" +
  "              \"board_order\": 0\n" +
  "            }\n" +
  "          }\n" +
  "        ],\n" +
  "        \"metadata\": {\n" +
  "          \"model\": \"codex/gpt-5.6-sol\",\n" +
  "          \"durable_owner\": \"moonbook\",\n" +
  "          \"agent_runtime\": \"moonclaw\",\n" +
  "          \"implementation_surface\": \"mooncode\",\n" +
  "          \"human_confirm_required\": true,\n" +
  "          \"auto_confirm\": false,\n" +
  "          \"role_runtime\": {\n" +
  "            \"role_id\": \"moonbook-mooncode-work-order\",\n" +
  "            \"planning_layer\": \"domain\",\n" +
  "            \"runtime_mode\": \"coding\",\n" +
  "            \"tool_access\": \"reviewed\",\n" +
  "            \"memory_scope\": \"work-order\",\n" +
  "            \"allow_delegate\": false,\n" +
  "            \"allow_workspace_write\": true,\n" +
  "            \"allow_execution_tools\": true,\n" +
  "            \"output_contract\": \"moonbook.bookkeeper.capability_adoption.v1\"\n" +
  "          }\n" +
  "        }\n" +
  "      },\n" +
  "      \"wiki_ingest_controller\": {\n" +
  "        \"family\": \"wiki_ingest_controller\",\n" +
  "        \"role\": \"controller\",\n" +
  "        \"priority\": 130,\n" +
  "        \"tags\": [\"wiki\", \"maintainer\", \"ingest\", \"source\"],\n" +
  "        \"match\": {\n" +
  "          \"all\": [\"wiki\"],\n" +
  "          \"any\": [\"ingest\", \"source\", \"integrate\", \"raw/\"]\n" +
  "        },\n" +
  "        \"steps\": [\n" +
  "          {\n" +
  "            \"id\": \"plan_gather_fanout\",\n" +
  "            \"title\": \"Plan gather worker fan-out\",\n" +
  "            \"kind\": \"job.analysis\",\n" +
  "            \"prompt_template\": \"Act as the book keeper for ${proposal.title}. Read the imported proposal request, notes, and gather lane specs first. Preserve the proposal's goal-adaptive evidence roles and specialize them to the subject. Do not substitute software-repository lanes for a scientific, physical, policy, or design goal, and do not compress multiple lanes into one worker unless the source surface is obviously tiny. Produce a concrete execution note for question framing, authoritative evidence, and alternatives or validation before gather begins.\",\n" +
  "            \"metadata\": {\n" +
  "              \"preferred_skills\": [\"wiki-maintainer\"],\n" +
  "              \"enable_tools\": true,\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Plan\",\n" +
  "              \"board_order\": 0\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"gather_question_framing\",\n" +
  "            \"title\": \"Frame research questions\",\n" +
  "            \"kind\": \"job.delegate\",\n" +
  "            \"request_template\": \"Act as the question-framing worker for ${proposal.title}. Read the proposal and source page, then write or improve raw/bootstrap/research-question.md with bounded unknowns, scope and exclusion boundaries, decision dependencies, and evidence requirements. Do not answer the questions, choose a design, or invent domain conclusions in this lane.\",\n" +
  "            \"child_profile\": \"wiki_gather_worker\",\n" +
  "            \"include_parent_outputs\": true,\n" +
  "            \"max_depth\": 3,\n" +
  "            \"metadata\": {\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Gather\",\n" +
  "              \"board_order\": 1\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"gather_authoritative_evidence\",\n" +
  "            \"title\": \"Gather authoritative evidence\",\n" +
  "            \"kind\": \"job.delegate\",\n" +
  "            \"request_template\": \"Act as the authoritative-evidence worker for ${proposal.title}. Use the bounded research questions to search and screen high-signal primary or authoritative sources appropriate to the subject. Write or improve raw/bootstrap/search-log.md, source-screen.md, and local-sources.md with URLs or paths, provenance, publication context, inclusion or rejection reasons, applicability limits, and disconfirming evidence. If remote tools are unavailable, record that limitation explicitly and do not imply web research occurred.\",\n" +
  "            \"child_profile\": \"wiki_gather_worker\",\n" +
  "            \"include_parent_outputs\": true,\n" +
  "            \"max_depth\": 3,\n" +
  "            \"metadata\": {\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Gather\",\n" +
  "              \"board_order\": 2\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"gather_alternatives_validation\",\n" +
  "            \"title\": \"Compare alternatives and validation\",\n" +
  "            \"kind\": \"job.delegate\",\n" +
  "            \"request_template\": \"Act as the alternatives-and-validation worker for ${proposal.title}. Compare relevant prior approaches or alternatives against the screened evidence. Write or improve raw/bootstrap/evidence-matrix.md with traceable tradeoffs, failure modes, disconfirming tests, acceptance evidence, uncertainty markers, and unresolved execution-critical questions. Keep recommendations provisional until authoritative evidence is available.\",\n" +
  "            \"child_profile\": \"wiki_gather_worker\",\n" +
  "            \"include_parent_outputs\": true,\n" +
  "            \"max_depth\": 3,\n" +
  "            \"metadata\": {\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Gather\",\n" +
  "              \"board_order\": 3\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"prepare_materials\",\n" +
  "            \"title\": \"Prepare ingestable materials\",\n" +
  "            \"kind\": \"job.delegate\",\n" +
  "            \"request_template\": \"Act as the wiki gather worker for the material-prep lane of ${proposal.title}. Consolidate the bounded gather outputs into ingestable raw packets under raw/bootstrap/: source summaries, evidence bullets, candidate pages to update, and explicit blockers when material is still too weak. Return the raw/bootstrap paths in artifacts. If the gathered material is not enough for MoonBook ingestion, say so explicitly and explain what is missing.\",\n" +
  "            \"child_profile\": \"wiki_gather_worker\",\n" +
  "            \"include_parent_outputs\": true,\n" +
  "            \"max_depth\": 3,\n" +
  "            \"metadata\": {\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Prepare\",\n" +
  "              \"board_order\": 4\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"inspect_source\",\n" +
  "            \"title\": \"Inspect provider-updated wiki state\",\n" +
  "            \"kind\": \"job.analysis\",\n" +
  "            \"prompt_template\": \"Act as the wiki maintainer keeper for ${proposal.title}. Review the gathered raw/bootstrap packets and provider-updated wiki state. Treat MoonBook as the owner of durable wiki writes, but verify whether the gathered material is actually strong enough for ingestion. Inspect `raw/bootstrap/`, `wiki/sources/`, `wiki/index.md`, `wiki/log.md`, the gather-worker outputs, and the most relevant entity, concept, synthesis, and query pages. Do not re-decide whether hidden placeholders, `.gitkeep`, or other workspace scaffolding count as substantive sources.\",\n" +
  "            \"metadata\": {\n" +
  "              \"preferred_skills\": [\"wiki-maintainer\"],\n" +
  "              \"enable_tools\": true,\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Inspect\",\n" +
  "              \"board_order\": 5\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"plan_revisions\",\n" +
  "            \"title\": \"Plan durable wiki revisions\",\n" +
  "            \"kind\": \"job.analysis\",\n" +
  "            \"prompt_template\": \"Turn the gathered raw/bootstrap materials and inspected wiki state for ${proposal.title} into a concrete MoonBook materialization plan. Separate: raw artifacts completed, source ids, entity candidates, concept candidates, synthesis claims, and blockers caused by weak materials. Treat generic completion text as failure, not success. Do not require MoonClaw to write durable wiki pages; MoonBook owns promotion into wiki/sources, wiki/entities, wiki/concepts, and synthesis pages from the raw research envelope.\",\n" +
  "            \"metadata\": {\n" +
  "              \"preferred_skills\": [\"wiki-maintainer\"],\n" +
  "              \"enable_tools\": true,\n" +
  "              \"web_search\": true,\n" +
  "              \"board_lane\": \"Plan\",\n" +
  "              \"board_order\": 6\n" +
  "            }\n" +
  "          },\n" +
  "          {\n" +
  "            \"id\": \"apply_revisions\",\n" +
  "            \"title\": \"Finalize research envelope\",\n" +
  "            \"kind\": \"job.delegate\",\n" +
  "            \"request_template\": \"Finalize the research envelope for ${proposal.title}. Read the prepared raw/bootstrap packets and make sure the required raw artifacts exist: research-question.md, search-log.md, source-screen.md, evidence-matrix.md, local-sources.md, synthesis-brief.md, and deep-report.md. Use the research-report skill to make deep-report.md a long-form evidence synthesis, not a checklist or promotional projection. Return those raw/bootstrap paths in artifacts. Do not edit durable wiki pages directly; MoonBook will materialize wiki/sources, wiki/entities, wiki/concepts, and synthesis pages from this envelope. If any required raw artifact is missing, return an explicit structured blocker.\",\n" +
  "            \"child_profile\": \"wiki_revision_worker\",\n" +
  "            \"include_parent_outputs\": true,\n" +
  "            \"max_depth\": 3,\n" +
  "            \"metadata\": {\n" +
  "              \"web_search\": true,\n" +
